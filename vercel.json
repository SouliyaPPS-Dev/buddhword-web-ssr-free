{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/css/(.*)",
      "dest": "/public/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/public/js/$1"
    },
    {
      "src": "/icons/(.*)",
      "dest": "/public/icons/$1"
    },
    {
      "src": "/images/(.*)",
      "dest": "/public/images/$1"
    },
    {
      "src": "/\\.well-known/(.*)",
      "dest": "/public/.well-known/$1"
    },
    {
      "src": "/(.*)\\.(png|jpg|jpeg|gif|svg|ico|webp|css|js|json|ttf|woff|woff2)$",
      "dest": "/public/$1.$2"
    },
    {
      "src": "/(manifest\\.json|sw\\.js|offline\\.html|robots\\.txt|privacy\\.html|favicon\\.ico|googled1932a80de1f4812\\.html)$",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api"
    }
  ]
}
